watch_file environment.yml

# Activate the micromamba `phage_env` environment. Micromamba is the canonical
# local-dev env manager per AGENTS.md — use it over conda/miniconda so local and
# CI share a single dependency-manifest source of truth (environment.yml →
# requirements.txt).
#
# direnv runs in a bare bash shell without .zshrc/.bashrc, so the `micromamba`
# shell function is not pre-installed. Evaluate the hook inline before activating.
MAMBA_EXE="${MAMBA_EXE:-$HOME/.local/bin/micromamba}"
if [ -x "$MAMBA_EXE" ]; then
  eval "$("$MAMBA_EXE" shell hook --shell bash)"
  micromamba activate phage_env
else
  echo "micromamba not found at $MAMBA_EXE; install micromamba before using this repository."
  exit 1
fi
